# ─── Supabase ───────────────────────────────────────────────
# จาก Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
# ใช้ service_role key (รันฝั่ง server เท่านั้น — bypass RLS) ห้ามเอาไปไว้ฝั่ง frontend
SUPABASE_SERVICE_ROLE_KEY=

# ─── LINE Messaging API ─────────────────────────────────────
# จาก LINE Developers Console → Messaging API channel → Channel access token (long-lived)
# หมายเหตุ: เป็นคนละ channel กับ LINE Login ที่ใช้ login เว็บ
LINE_CHANNEL_ACCESS_TOKEN=

# ─── โลโก้ในใบเสร็จ ─────────────────────────────────────────
# LINE Flex โหลดรูปจากไฟล์ local ไม่ได้ ต้องเป็น public https
# อัปโหลด logo.png ขึ้น Supabase Storage (public bucket) แล้วเอา URL มาวาง
LOGO_URL=https://xxxxxxxx.supabase.co/storage/v1/object/public/assets/logo.png

# ─── ความปลอดภัยของ webhook ─────────────────────────────────
# ตั้งค่าเอง (สุ่มยาวๆ) แล้วเอาไปใส่เป็น header X-Webhook-Secret ฝั่ง Supabase webhook
WEBHOOK_SECRET=change-me-to-a-long-random-string

# ─── ข้อมูลร้าน ─────────────────────────────────────────────
SHOP_PHONE=082-325-8380
