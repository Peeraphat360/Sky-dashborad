# Supabase project URL — e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase public anon key (safe to expose in the browser; rely on RLS for security)
VITE_SUPABASE_ANON_KEY=

# NestJS backend base URL (LINE login + booking confirm). Defaults to http://localhost:3001
VITE_API_URL=http://localhost:3001
